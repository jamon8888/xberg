# Copy to .env (next to docker-compose.yml) and fill in real values.
# .env is gitignored at the repo root — do not commit the real one.

# `docker compose build` target — aarch64-unknown-linux-musl for Ampere A1
# (Always Free ARM), x86_64-unknown-linux-musl if you ever run this on an
# x86_64 host instead.
NAPI_TARGET=aarch64-unknown-linux-musl

# Fixed auth token for /ui, /sse, /message, /ingest, /map, /collection,
# /admin. Generate one with: openssl rand -hex 32
XBERG_MCP_UI_TOKEN=

# From the Cloudflare Zero Trust dashboard: Networks > Tunnels > Create a
# tunnel (Cloudflared connector) > copy the token shown in the install step.
# Set the tunnel's public hostname to route to http://mcp-server:8080.
CLOUDFLARE_TUNNEL_TOKEN=

# Optional — only needed for the default ONNX NER path against the private
# xberg-io/gliner-models catalog. See mcp-server/README.md.
HF_TOKEN=
